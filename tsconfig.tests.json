{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "outDir": "dist-tests",
    "rootDir": ".",
    "types": ["@cloudflare/workers-types", "node"],
    "lib": ["ES2022"],
    // skipLibCheck required: both @cloudflare/workers-types and node define
    // overlapping globals (console, crypto, URL, etc.) causing type conflicts.
    // Tests need both for Cloudflare worker tests and Node runtime tests.
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts", "test/**/*.test.ts"],
  "exclude": ["dist-tests"]
}
